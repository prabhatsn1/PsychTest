generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
}

model Report {
  id               String   @id @default(cuid())
  studentName      String
  mobile           String   @unique
  classSection     String
  dateOfAssessment DateTime
  scoreA           Int      @default(0)
  scoreB           Int      @default(0)
  scoreC           Int      @default(0)
  scoreD           Int      @default(0)
  pdfPath          String
  reportOpenedAt   DateTime?
  reportOpenCount  Int      @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model Assessment {
  id           String   @id @default(cuid())
  studentName  String
  mobile       String
  classSection String
  q1           String
  q2           String
  q3           String
  q4           String
  q5           String
  q6           String
  q7           String
  q8           String
  q9           String
  q10          String
  scoreA       Int      @default(0)
  scoreB       Int      @default(0)
  scoreC       Int      @default(0)
  scoreD       Int      @default(0)
  createdAt    DateTime @default(now())
}
